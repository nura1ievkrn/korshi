@model korshi.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Панель управления";
    ViewData["AdminNav"] = "dashboard";
}

<!-- Приветствие -->
<div class="adm-greeting">
    <div>
        <h1 class="adm-greeting__title">Добрый день, Председатель ОСИ</h1>
        <p class="adm-greeting__sub">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
</div>

<!-- Стат-карточки -->
<div class="adm-stats">

    <div class="adm-stat-card">
        <div class="adm-stat-card__icon" style="background:#EFF6FF; color:#3B82F6;">
            <i class="bi bi-people-fill"></i>
        </div>
        <div class="adm-stat-card__body">
            <div class="adm-stat-card__num" data-countup="@Model.TotalUsers">@Model.TotalUsers</div>
            <div class="adm-stat-card__label">Всего жильцов</div>
        </div>
    </div>

    <div class="adm-stat-card adm-stat-card--urgent">
        <div class="adm-stat-card__icon" style="background:#FFF7ED; color:#F59E0B;">
            <i class="bi bi-person-exclamation"></i>
        </div>
        <div class="adm-stat-card__body">
            <div class="adm-stat-card__num" data-countup="@Model.PendingUsers">@Model.PendingUsers</div>
            <div class="adm-stat-card__label">Ожидают подтверждения</div>
        </div>
        @if (Model.PendingUsers > 0)
        {
            <a href="/Admin/Users?filter=pending" class="adm-stat-card__action">
                Рассмотреть <i class="bi bi-arrow-right"></i>
            </a>
        }
    </div>

    <div class="adm-stat-card">
        <div class="adm-stat-card__icon" style="background:#F0FDF4; color:#10B981;">
            <i class="bi bi-file-text"></i>
        </div>
        <div class="adm-stat-card__body">
            <div class="adm-stat-card__num" data-countup="@Model.TotalPosts">@Model.TotalPosts</div>
            <div class="adm-stat-card__label">Всего публикаций</div>
        </div>
    </div>

    <div class="adm-stat-card">
        <div class="adm-stat-card__icon" style="background:#FFF0F0; color:#EF4444;">
            <i class="bi bi-wrench"></i>
        </div>
        <div class="adm-stat-card__body">
            <div class="adm-stat-card__num" data-countup="@Model.OpenRequests">@Model.OpenRequests</div>
            <div class="adm-stat-card__label">Открытых заявок</div>
        </div>
    </div>

</div>

<!-- Ожидающие верификации -->
@if (Model.PendingList.Any())
{
    <div class="adm-section">
        <div class="adm-section__header">
            <h2 class="adm-section__title">
                <i class="bi bi-person-check" style="color:#F59E0B;"></i>
                Ожидают подтверждения
            </h2>
            <a href="/Admin/Users?filter=pending" class="kw-btn-secondary" style="font-size:13px; height:34px;">
                Все заявки
            </a>
        </div>

        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Жилец</th>
                        <th>Квартира</th>
                        <th>Телефон</th>
                        <th>Дата регистрации</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.PendingList)
                    {
                        <tr>
                            <td>
                                <div class="adm-user-cell">
                                    <div class="kw-avatar" style="width:32px;height:32px;font-size:11px;">
                                        @user.Initials
                                    </div>
                                    <div>
                                        <div style="font-weight:600; font-size:14px;">@user.FullName</div>
                                        <div style="font-size:12px; color:var(--text-muted);">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.ApartmentNumber))
                                {
                                    <span class="kw-apt-badge">кв. @user.ApartmentNumber</span>
                                }
                            </td>
                            <td style="font-size:13px; color:var(--text-muted);">
                                @user.PhoneNumber
                            </td>
                            <td style="font-size:13px; color:var(--text-muted);">
                                @user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                <div style="display:flex; gap:8px;">
                                    <form asp-action="Verify" asp-controller="Admin" asp-area="Admin"
                                          asp-route-id="@user.Id" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn adm-btn--success">
                                            <i class="bi bi-check-lg"></i>
                                            Подтвердить
                                        </button>
                                    </form>
                                    <form asp-action="Ban" asp-controller="Admin" asp-area="Admin"
                                          asp-route-id="@user.Id" method="post"
                                          onsubmit="return confirm('Заблокировать пользователя?')"
                                          style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn adm-btn--danger">
                                            <i class="bi bi-x-lg"></i>
                                            Отклонить
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="adm-section">
        <div class="adm-empty">
            <i class="bi bi-check-circle" style="font-size:40px; color:#10B981; opacity:0.6;"></i>
            <div style="font-size:15px; font-weight:600; margin-top:10px;">Все заявки рассмотрены</div>
            <div style="font-size:13px; color:var(--text-muted);">Новых запросов на верификацию нет</div>
        </div>
    </div>
}

<!-- Уведомления -->
@if (TempData["Success"] != null)
{
    <div class="kw-alert-success" style="position:fixed; bottom:24px; right:24px; z-index:200; max-width:320px; box-shadow:0 4px 16px rgba(0,0,0,0.1);">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}
