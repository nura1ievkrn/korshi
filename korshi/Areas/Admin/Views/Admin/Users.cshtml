@model List<korshi.Models.ApplicationUser>
@{
    ViewData["Title"] = "Жильцы";
    ViewData["AdminNav"] = "users";
    var filter = ViewData["Filter"]?.ToString() ?? "all";
}

<div class="adm-page-header">
    <h1 class="adm-page-title">Управление жильцами</h1>
</div>

<!-- Фильтры -->
<div class="adm-filter-tabs">
    <a href="/Admin/Admin/Users" class="adm-filter-tab @(filter == "all" ? "adm-filter-tab--active" : "")">
        Все
    </a>
    <a href="/Admin/Admin/Users?filter=pending" class="adm-filter-tab @(filter == "pending" ? "adm-filter-tab--active" : "")">
        <i class="bi bi-clock" style="color:#F59E0B;"></i>
        Ожидают
    </a>
    <a href="/Admin/Admin/Users?filter=active" class="adm-filter-tab @(filter == "active" ? "adm-filter-tab--active" : "")">
        <i class="bi bi-check-circle" style="color:#10B981;"></i>
        Активные
    </a>
    <a href="/Admin/Admin/Users?filter=banned" class="adm-filter-tab @(filter == "banned" ? "adm-filter-tab--active" : "")">
        <i class="bi bi-slash-circle" style="color:#EF4444;"></i>
        Заблокированные
    </a>
</div>

<!-- Уведомления -->
@if (TempData["Success"] != null)
{
    <div class="kw-alert-success" style="margin-bottom:16px;">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="display:flex;align-items:center;gap:8px;background:#FFF0F0;border:1px solid #FCA5A5;border-radius:10px;padding:12px 16px;margin-bottom:16px;font-size:14px;color:#991B1B;">
        <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
    </div>
}

<!-- Таблица -->
@if (!Model.Any())
{
    <div class="adm-empty">
        <i class="bi bi-people" style="font-size:40px; color:var(--text-muted); opacity:0.4;"></i>
        <div style="font-size:15px; font-weight:600; margin-top:10px; color:var(--text-muted);">
            Пользователей нет
        </div>
    </div>
}
else
{
    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Жилец</th>
                    <th>Квартира</th>
                    <th>Телефон</th>
                    <th>Дата регистрации</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="adm-user-cell">
                                <div class="kw-avatar" style="width:36px;height:36px;font-size:12px;flex-shrink:0;">
                                    @user.Initials
                                </div>
                                <div>
                                    <div style="font-weight:600; font-size:14px;">@user.FullName</div>
                                    <div style="font-size:12px; color:var(--text-muted);">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(user.ApartmentNumber))
                            {
                                <span class="kw-apt-badge">кв. @user.ApartmentNumber</span>
                            }
                            else
                            {

                                <span style="color:var(--text-muted);font-size:13px;">—</span>
                            }
                        </td>
                        <td style="font-size:13px; color:var(--text-muted);">
                            @(user.PhoneNumber ?? "—")
                        </td>
                        <td style="font-size:13px; color:var(--text-muted);">
                            @user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                        </td>
                        <td>
                            @if (user.IsBanned)
                            {
                                <span class="adm-badge adm-badge--red">Заблокирован</span>
                            }
                            else if (!user.IsVerified)
                            {
                                <span class="adm-badge adm-badge--yellow">Ожидает</span>
                            }
                            else
                            {
                                <span class="adm-badge adm-badge--green">Активен</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                @if (!user.IsVerified && !user.IsBanned)
                                {
                                    <form asp-action="Verify" asp-controller="Admin" asp-area="Admin"
                                          asp-route-id="@user.Id" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn adm-btn--success adm-btn--sm">
                                            <i class="bi bi-check-lg"></i> Подтвердить
                                        </button>
                                    </form>
                                }
                                @if (!user.IsBanned)
                                {
                                    <form asp-action="Ban" asp-controller="Admin" asp-area="Admin"
                                          asp-route-id="@user.Id" method="post"
                                          onsubmit="return confirm('Заблокировать @user.FullName?')"
                                          style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn adm-btn--danger adm-btn--sm">
                                            <i class="bi bi-slash-circle"></i> Бан
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Unban" asp-controller="Admin" asp-area="Admin"
                                          asp-route-id="@user.Id" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="adm-btn adm-btn--neutral adm-btn--sm">
                                            <i class="bi bi-unlock"></i> Разблокировать
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
