@model List<korshi.Models.Category>
@{
    ViewData["Title"] = "Категории";
    ViewData["AdminNav"] = "categories";
}

<div class="adm-page-header">
    <h1 class="adm-page-title">Управление категориями</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="kw-alert-success" style="margin-bottom:16px;">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- Форма добавления -->
<div class="adm-section" style="margin-bottom:20px;">
    <div class="adm-section__header">
        <h2 class="adm-section__title">
            <i class="bi bi-plus-circle" style="color:var(--accent);"></i>
            Добавить категорию
        </h2>
    </div>

    <form asp-action="CreateCategory" asp-controller="Admin" asp-area="Admin" method="post">
        @Html.AntiForgeryToken()

        <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:12px; align-items:end;">
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Название</label>
                <input type="text" name="Name" class="kw-input" placeholder="Объявления" required />
            </div>
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Slug (латиницей)</label>
                <input type="text" name="Slug" class="kw-input" placeholder="announcements" required />
            </div>
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Bootstrap иконка</label>
                <input type="text" name="Icon" class="kw-input" placeholder="bi-megaphone" value="bi-tag" />
            </div>
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Цвет</label>
                <input type="color" name="Color" value="#6B7280"
                       style="width:100%; height:44px; border-radius:8px; border:1px solid var(--border); cursor:pointer; padding:2px;" />
            </div>
        </div>

        <div style="margin-top:12px; display:flex; justify-content:flex-end;">
            <button type="submit" class="kw-btn-primary">
                <i class="bi bi-plus-lg"></i>
                Добавить
            </button>
        </div>
    </form>
</div>

<!-- Список категорий -->
<div class="adm-section">
    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Категория</th>
                    <th>Slug</th>
                    <th>Иконка</th>
                    <th>Постов</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model.OrderBy(c => c.SortOrder))
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div style="width:32px; height:32px; border-radius:8px;
                                                background:@cat.Color + " 18"; display:flex;
                                     align-items:center; justify-content:center;
                                     color: @cat.Color; font-size:15px;">
                                    <i class="@cat.Icon"></i>
                                </div>
                                <span style="font-weight:600; font-size:14px;">@cat.Name</span>
                            </div>
                        </td>
                        <td style="font-size:12px; font-family:monospace; color:var(--text-muted);">@cat.Slug</td>
                        <td style="font-size:12px; font-family:monospace; color:var(--text-muted);">@cat.Icon</td>
                        <td style="font-size:13px;">@cat.Posts?.Count</td>
                        <td>
                            @if (cat.IsActive)
                            {
                                <span class="adm-badge adm-badge--green">Активна</span>
                            }
                            else
                            {
                                <span class="adm-badge adm-badge--red">Скрыта</span>
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleCategory" asp-controller="Admin" asp-area="Admin"
                                  asp-route-id="@cat.Id" method="post" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="adm-btn adm-btn--neutral adm-btn--sm">
                                    @(cat.IsActive ? "Скрыть" : "Показать")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
