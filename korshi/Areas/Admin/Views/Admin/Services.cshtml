@model List<korshi.Models.Service>
@{
    ViewData["Title"] = "Услуги";
    ViewData["AdminNav"] = "services";
}

<div class="adm-page-header">
    <h1 class="adm-page-title">Управление услугами</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="kw-alert-success" style="margin-bottom:16px;">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- Форма добавления услуги -->
<div class="adm-section" style="margin-bottom:20px;">
    <div class="adm-section__header">
        <h2 class="adm-section__title">
            <i class="bi bi-plus-circle" style="color:var(--accent);"></i>
            Добавить услугу
        </h2>
    </div>

    <form asp-action="CreateService" asp-controller="Admin" asp-area="Admin" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div style="display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:12px; align-items:end;">
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Название</label>
                <input type="text" name="Name" class="kw-input"
                       placeholder="Например: Клининг" required maxlength="50" />
            </div>
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Описание</label>
                <input type="text" name="Description" class="kw-input"
                       placeholder="Уборка квартиры" maxlength="100" />
            </div>
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Bootstrap иконка</label>
                <input type="text" name="Icon" class="kw-input"
                       placeholder="bi-stars" value="bi-wrench" />
            </div>
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Цвет (hex)</label>
                <div style="display:flex; gap:8px; align-items:center;">
                    <input type="color" name="Color" value="#6B7280"
                           style="width:44px; height:44px; border-radius:8px; border:1px solid var(--border); cursor:pointer; padding:2px;" />
                    <input type="text" name="ColorText" class="kw-input"
                           placeholder="#6B7280" value="#6B7280"
                           style="flex:1;" maxlength="7" />
                </div>
            </div>
        </div>

        <div style="margin-top:12px; display:flex; justify-content:flex-end;">
            <button type="submit" class="kw-btn-primary">
                <i class="bi bi-plus-lg"></i>
                Добавить услугу
            </button>
        </div>
    </form>
</div>

<!-- Список услуг -->
<div class="adm-section">
    <div class="adm-section__header">
        <h2 class="adm-section__title">
            <i class="bi bi-list-ul"></i>
            Все услуги
        </h2>
    </div>

    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Услуга</th>
                    <th>Описание</th>
                    <th>Иконка</th>
                    <th>Заявок</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in Model.OrderBy(s => s.SortOrder))
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div style="width:36px; height:36px; border-radius:10px;
                                                background:@service.Color + " 18"; display:flex;
                                     align-items:center; justify-content:center; font-size:16px;
                                     color: @service.Color;">
                                    <i class="@service.Icon"></i>
                                </div>
                                <span style="font-weight:600; font-size:14px;">@service.Name</span>
                            </div>
                        </td>
                        <td style="font-size:13px; color:var(--text-muted);">@service.Description</td>
                        <td style="font-size:12px; font-family:monospace; color:var(--text-muted);">@service.Icon</td>
                        <td style="font-size:13px;">@service.Requests?.Count</td>
                        <td>
                            @if (service.IsActive)
                            {
                                <span class="adm-badge adm-badge--green">Активна</span>
                            }
                            else
                            {
                                <span class="adm-badge adm-badge--red">Скрыта</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <form asp-action="ToggleService" asp-controller="Admin" asp-area="Admin"
                                      asp-route-id="@service.Id" method="post" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="adm-btn adm-btn--neutral adm-btn--sm">
                                        @(service.IsActive ? "Скрыть" : "Показать")
                                    </button>
                                </form>
                                <form asp-action="DeleteService" asp-controller="Admin" asp-area="Admin"
                                      asp-route-id="@service.Id" method="post"
                                      onsubmit="return confirm('Удалить услугу?')" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="adm-btn adm-btn--danger adm-btn--sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
