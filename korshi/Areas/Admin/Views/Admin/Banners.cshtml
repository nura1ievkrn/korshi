@model List<korshi.Models.Banner>
@{
    ViewData["Title"] = "Баннеры";
    ViewData["AdminNav"] = "banners";
}

<div class="adm-page-header">
    <h1 class="adm-page-title">Управление баннерами</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="kw-alert-success" style="margin-bottom:16px;">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- Форма создания баннера -->
<div class="adm-section" style="margin-bottom:20px;">
    <div class="adm-section__header">
        <h2 class="adm-section__title">
            <i class="bi bi-plus-circle" style="color:var(--accent);"></i>
            Новый баннер
        </h2>
    </div>

    <form asp-action="CreateBanner" asp-controller="Admin" asp-area="Admin" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div style="display:grid; grid-template-columns:1fr auto auto; gap:12px; align-items:end;">
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Текст баннера</label>
                <input type="text" name="Message" class="kw-input"
                       placeholder="Например: Отключение горячей воды 25 апреля с 10:00 до 16:00"
                       required maxlength="300" />
            </div>

            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Тип</label>
                <select name="Type" class="kw-sort__select" style="height:44px; padding:0 14px;">
                    <option value="1">🔴 Авария</option>
                    <option value="0">🔵 Инфо</option>
                </select>
            </div>

            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Истекает</label>
                <input type="datetime-local" name="ExpiresAt" class="kw-input"
                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
            </div>
        </div>

        <div style="margin-top:12px; display:flex; justify-content:flex-end;">
            <button type="submit" class="kw-btn-primary">
                <i class="bi bi-megaphone"></i>
                Опубликовать баннер
            </button>
        </div>
    </form>
</div>

<!-- Список баннеров -->
<div class="adm-section">
    <div class="adm-section__header">
        <h2 class="adm-section__title">
            <i class="bi bi-list-ul"></i>
            Активные баннеры
        </h2>
    </div>

    @if (!Model.Any())
    {
        <div class="adm-empty">
            <i class="bi bi-megaphone" style="font-size:36px; color:var(--text-muted); opacity:0.3;"></i>
            <div style="font-size:14px; color:var(--text-muted); margin-top:10px;">Баннеров нет</div>
        </div>
    }
    else
    {
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Сообщение</th>
                        <th>Тип</th>
                        <th>Создан</th>
                        <th>Истекает</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var banner in Model)
                    {
                        <tr>
                            <td style="font-size:13px; max-width:300px;">@banner.Message</td>
                            <td>
                                @if (banner.Type == korshi.Models.BannerType.Emergency)
                                {
                                    <span class="adm-badge adm-badge--red">Авария</span>
                                }
                                else
                                {
                                    <span class="adm-badge adm-badge--blue">Инфо</span>
                                }
                        </td>
                        <td style="font-size:12px; color:var(--text-muted);">
                            @banner.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </td>
                        <td style="font-size:12px; color:var(--text-muted);">
                            @(banner.ExpiresAt.HasValue
                                                    ? banner.ExpiresAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                                    : "Бессрочно")
                    </td>
                    <td>
                        @if (!banner.IsActive || banner.IsExpired)
                                {
                                    <span class="adm-badge adm-badge--red">Неактивен</span>
                                }
                                else
                                {
                                    <span class="adm-badge adm-badge--green">Активен</span>
                                }
                            </td>
                            <td>
                                <form asp-action="DeleteBanner" asp-controller="Admin" asp-area="Admin"
                                      asp-route-id="@banner.Id" method="post"
                                      onsubmit="return confirm('Удалить баннер?')" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="adm-btn adm-btn--danger adm-btn--sm">
                                        <i class="bi bi-trash"></i> Удалить
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
