@model List<korshi.Models.Event>
@{
    ViewData["Title"] = "События";
    ViewData["AdminNav"] = "events";
}

<div class="adm-page-header">
    <h1 class="adm-page-title">Предстоящие события</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="kw-alert-success" style="margin-bottom:16px;">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- Форма создания -->
<div class="adm-section" style="margin-bottom:20px;">
    <div class="adm-section__header">
        <h2 class="adm-section__title">
            <i class="bi bi-plus-circle" style="color:var(--accent);"></i>
            Новое событие
        </h2>
    </div>

    <form asp-action="CreateEvent" asp-controller="Admin" asp-area="Admin" method="post">
        @Html.AntiForgeryToken()

        <div style="display:grid; grid-template-columns:2fr 1fr; gap:12px; align-items:end;">
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Название события</label>
                <input type="text" name="Title" class="kw-input"
                       placeholder="Например: Субботник у дома" required maxlength="150" />
            </div>
            <div class="kw-field" style="margin-bottom:0;">
                <label class="kw-label">Дата и время</label>
                <input type="datetime-local" name="EventDate" class="kw-input"
                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
            </div>
        </div>

        <div class="kw-field" style="margin-top:12px; margin-bottom:0;">
            <label class="kw-label">Описание (необязательно)</label>
            <input type="text" name="Description" class="kw-input"
                   placeholder="Краткое описание события" maxlength="300" />
        </div>

        <div style="margin-top:12px; display:flex; justify-content:flex-end;">
            <button type="submit" class="kw-btn-primary">
                <i class="bi bi-calendar-plus"></i>
                Добавить событие
            </button>
        </div>
    </form>
</div>

<!-- Список событий -->
<div class="adm-section">
    <div class="adm-section__header">
        <h2 class="adm-section__title">
            <i class="bi bi-calendar3"></i>
            Все события
        </h2>
    </div>

    @if (!Model.Any())
    {
        <div class="adm-empty">
            <i class="bi bi-calendar3" style="font-size:36px; color:var(--text-muted); opacity:0.3;"></i>
            <div style="font-size:14px; color:var(--text-muted); margin-top:10px;">
                Событий пока нет
            </div>
        </div>
    }
    else
    {
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Описание</th>
                        <th>Дата события</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in Model.OrderBy(e => e.EventDate))
                    {
                        var isPast = ev.EventDate < DateTime.UtcNow;
                        <tr>
                            <td style="font-weight:600; font-size:14px;">@ev.Title</td>
                            <td style="font-size:13px; color:var(--text-muted);">
                                @(ev.Description ?? "—")
                            </td>
                            <td style="font-size:13px;">
                                @ev.EventDate.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                            </td>
                            <td>
                                @if (isPast)
                                {
                                    <span class="adm-badge adm-badge--red">Прошло</span>
                                }
                                else
                                {
                                    <span class="adm-badge adm-badge--green">Предстоит</span>
                                }
                            </td>
                            <td>
                                <form asp-action="DeleteEvent" asp-controller="Admin" asp-area="Admin"
                                      asp-route-id="@ev.Id" method="post"
                                      onsubmit="return confirm('Удалить событие?')"
                                      style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="adm-btn adm-btn--danger adm-btn--sm">
                                        <i class="bi bi-trash"></i> Удалить
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
