@using Microsoft.AspNetCore.Identity
@using korshi.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var initials = currentUser?.Initials ?? "АД";
    var fullName = currentUser?.FullName ?? "Администратор";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Админ | KÖRSHI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

    <!-- HEADER -->
    <header class="kw-header">
        <div class="kw-header__left">
            <a href="/Admin" class="kw-logo">KÖRSHI</a>
            <span class="kw-complex-badge" style="background:#FFF0EB; color:#E8450A;">
                Панель ОСИ
            </span>
        </div>
        <div class="kw-header__right">
            <a href="/Feed" class="kw-header-login-btn" style="background:#1E293B;">
                <i class="bi bi-arrow-left"></i>
                К сайту
            </a>
            <div class="kw-avatar kw-avatar--header">@initials</div>
        </div>
    </header>

    <!-- LAYOUT -->
    <div class="kw-layout">

        <!-- SIDEBAR -->
        <aside class="kw-sidebar" id="sidebar">
            <div class="kw-sidebar__user">
                <div class="kw-avatar kw-avatar--lg">@initials</div>
                <div class="kw-sidebar__user-info">
                    <div class="kw-sidebar__username">
                        @currentUser?.FirstName
                        <i class="bi bi-shield-fill-check" style="color:#E8450A; font-size:12px;"></i>
                    </div>
                    <span class="kw-apt-badge" style="background:#E8450A;">Председатель ОСИ</span>
                </div>
            </div>

            <nav class="kw-sidebar__nav">
                <div class="kw-nav-group">
                    <span class="kw-nav-label">УПРАВЛЕНИЕ</span>

                    <a href="/Admin" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "dashboard" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-grid"></i>
                        <span>Главная</span>
                    </a>

                    <a href="/Admin/Admin/Users" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "users" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-people"></i>
                        <span>Жильцы</span>
                        @if (ViewBag.PendingCount > 0)
                        {
                            <span class="kw-nav-badge">@ViewBag.PendingCount</span>
                        }
                    </a>

                    <a href="/Admin/Admin/Users?filter=pending" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "pending" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-person-check"></i>
                        <span>Ожидают подтверждения</span>
                    </a>
                </div>

                <div class="kw-nav-group">
                    <span class="kw-nav-label">КОНТЕНТ</span>

                    <a href="/Admin/Admin/ServiceRequests" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "requests" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-wrench"></i>
                        <span>Заявки на ремонт</span>
                    </a>

                    <a href="/Admin/Admin/Banners" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "banners" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-megaphone"></i>
                        <span>Баннеры</span>
                    </a>

                    <a href="/Admin/Admin/Services" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "services" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-wrench"></i>
                        <span>Услуги</span>
                    </a>

                    <a href="/Admin/Admin/Categories" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "categories" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-tags"></i>
                        <span>Категории</span>
                    </a>

                    <a href="/Admin/Admin/Events" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "events" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-calendar3"></i>
                        <span>События</span>
                    </a>
                    <a href="/Admin/Admin/Announcements" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "announcements" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-megaphone"></i>
                        <span>Объявления ОСИ</span>
                    </a>

                    <a href="/Admin/Admin/FinancialReports" class="kw-nav-item @(ViewData["AdminNav"]?.ToString() == "reports" ? "kw-nav-item--active" : "")">
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>Финансовые отчёты</span>
                    </a>
                </div>

                <div class="kw-nav-group">
                    <span class="kw-nav-label">АККАУНТ</span>
                    <form asp-action="Logout" asp-controller="Account" asp-area="" method="post" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="kw-nav-item kw-nav-item--logout"
                                style="width:100%; text-align:left; background:none; border:none;">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Выйти</span>
                        </button>
                    </form>
                </div>
            </nav>
        </aside>

        <!-- MAIN -->
        <main class="kw-main" style="margin-right:0;">
            @RenderBody()
        </main>
    </div>

    <div class="kw-toast-container" id="toastContainer"></div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
