@model korshi.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Смена пароля";
    ViewData["ActiveNav"] = "settings";
}

<div class="kw-form-page">
    <div class="kw-form-card">

        <div class="kw-form-card__header">
            <a href="/Profile" class="kw-back-btn">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="kw-form-card__title">Смена пароля</h1>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert">
                <i class="bi bi-exclamation-circle"></i>
                <div>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            </div>
        }

        <form asp-action="ChangePassword" asp-controller="Profile" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="kw-field">
                <label asp-for="CurrentPassword" class="kw-label"></label>
                <div class="auth-input-wrap">
                    <i class="bi bi-lock auth-input-icon"></i>
                    <input asp-for="CurrentPassword" class="kw-input" style="padding-left:38px;"
                           type="password" placeholder="Текущий пароль"
                           id="curPwd" />
                    <button type="button" class="auth-eye"
                            onclick="togglePwd('curPwd','eye1')" tabindex="-1">
                        <i class="bi bi-eye" id="eye1"></i>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="auth-error"></span>
            </div>

            <div class="kw-field">
                <label asp-for="NewPassword" class="kw-label"></label>
                <div class="auth-input-wrap">
                    <i class="bi bi-lock-fill auth-input-icon"></i>
                    <input asp-for="NewPassword" class="kw-input" style="padding-left:38px;"
                           type="password" placeholder="Минимум 6 символов"
                           id="newPwd" />
                    <button type="button" class="auth-eye"
                            onclick="togglePwd('newPwd','eye2')" tabindex="-1">
                        <i class="bi bi-eye" id="eye2"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="auth-error"></span>
            </div>

            <div class="kw-field">
                <label asp-for="ConfirmPassword" class="kw-label"></label>
                <div class="auth-input-wrap">
                    <i class="bi bi-lock-fill auth-input-icon"></i>
                    <input asp-for="ConfirmPassword" class="kw-input" style="padding-left:38px;"
                           type="password" placeholder="Повторите новый пароль"
                           id="conPwd" />
                    <button type="button" class="auth-eye"
                            onclick="togglePwd('conPwd','eye3')" tabindex="-1">
                        <i class="bi bi-eye" id="eye3"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
            </div>

            <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:8px;">
                <a href="/Profile" class="kw-btn-secondary">Отмена</a>
                <button type="submit" class="kw-btn-primary">
                    <i class="bi bi-shield-check"></i>
                    Изменить пароль
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <script>
        function togglePwd(fieldId, iconId) {
            const f = document.getElementById(fieldId);
            const i = document.getElementById(iconId);
            if (f.type === 'password') { f.type = 'text'; i.className = 'bi bi-eye-slash'; }
            else { f.type = 'password'; i.className = 'bi bi-eye'; }
        }
    </script>
}
